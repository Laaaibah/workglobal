---
import Layout from '../layouts/Layout.astro';
import bgImage from '../assets/background.png?url';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What is Work Global?",
    answer: "Work Global is a platform that connects professionals with global opportunities, making it easy to find remote and international roles.",
  },
  {
    question: "How do I create an account?",
    answer: "Simply click 'Sign Up' on the homepage, fill in your details, and you're ready to start exploring opportunities worldwide.",
  },
  {
    question: "Is Work Global free to use?",
    answer: "Yes! Basic access is completely free. We also offer premium plans with advanced features for power users.",
  },
  {
    question: "How can I contact support?",
    answer: "You can reach our support team via the contact form on this page, by email, or through our live chat available on weekdays.",
  },
  {
    question: "What countries are supported?",
    answer: "Work Global supports professionals and employers across 120+ countries. Check our coverage page for the full list.",
  },
  {
    question: "Can I post jobs on Work Global?",
    answer: "Absolutely! Employers can post jobs, manage applications, and access a global talent pool directly from their dashboard.",
  },
  {
    question: "How long does it take to get a response?",
    answer: "Our support team typically responds within 24 hours on business days. Premium users receive priority responses within 4 hours.",
  },
  {
    question: "Is my data safe with Work Global?",
    answer: "Yes. We use industry-standard encryption and never share your personal data with third parties without your consent.",
  },
  {
    question: "How do I reset my password?",
    answer: "Click 'Forgot Password' on the login page and follow the instructions sent to your registered email address.",
  },
  {
    question: "Can I use Work Global on mobile?",
    answer: "Yes! Work Global is fully responsive and also available as a mobile app on iOS and Android.",
  },
  {
    question: "What payment methods are accepted?",
    answer: "We accept all major credit cards, PayPal, and bank transfers for premium subscriptions.",
  },
  {
    question: "How do I delete my account?",
    answer: "You can request account deletion from your profile settings. Our team will process it within 7 business days.",
  },
  {
    question: "Do you offer a referral program?",
    answer: "Yes! Refer a friend and both of you get one month of premium access for free. Check your dashboard for your unique referral link.",
  },
  {
    question: "Where can I find the privacy policy?",
    answer: "Our full privacy policy is available in the footer of every page and at workglobal.com/privacy.",
  },
  {
    question: "Are there webinars or tutorials?",
    answer: "We host free weekly webinars and have a full library of video tutorials available in the Help Center.",
  },
  {
    question: "Can I change my subscription plan?",
    answer: "Yes, you can upgrade or downgrade your plan at any time from your account settings. Changes take effect on the next billing cycle.",
  },
];
---

<Layout title="Support Center - WorkGlobal" navActive="support">
  <style define:vars={{ bgImage: `url(${bgImage})` }}>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --navy: #053F5C;
        --light-blue: #86C5FF;
        --orange: #FFA62B;
        --bg: #ddeef8;
      }

      body {
        font-family: 'Nunito', sans-serif;
        background-color: var(--bg);
        min-height: 100vh;
        padding: 0;
      }

      .bg-layer {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: var(--bgImage);
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        opacity: 0.6;
        z-index: -1;
        pointer-events: none;
      }

      .page-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 60px;
        width: 100%;
        min-height: 100vh;
        padding: 40px 20px;
      }

      /* ── LEFT PANEL ── */
      .left-panel {
        flex: 1;
        max-width: 380px;
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .mascot-placeholder {
        width: 120px;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .mascot-img {
        width: 120px;
        height: auto;
        display: block;
      }

      .heading-block h1 {
        font-size: 1.65rem;
        font-weight: 900;
        color: var(--navy);
        letter-spacing: 0.02em;
        text-transform: uppercase;
        line-height: 1.2;
      }

      .heading-block p {
        margin-top: 10px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #4a6a80;
        line-height: 1.6;
        max-width: 280px;
      }

      .contact-list {
        display: flex;
        flex-direction: column;
        gap: 18px;
        list-style: none;
      }

      .contact-list li {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .icon-circle {
        width: 44px;
        height: 44px;
        min-width: 44px;
        border-radius: 50%;
        background-color: var(--orange);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .icon-circle svg {
        width: 20px;
        height: 20px;
        fill: #fff;
      }

      .contact-list li span {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--navy);
        line-height: 1.4;
      }

      /* ── RIGHT PANEL — FORM CARD ── */
      .form-card {
        flex: 0 0 480px;
        background: linear-gradient(160deg, #5bacd8 0%, var(--navy) 100%);
        border-radius: 24px;
        padding: 36px 32px 40px;
        box-shadow: 0 20px 60px rgba(5, 63, 92, 0.3);
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-bottom: 16px;
      }

      .form-group:last-of-type {
        margin-bottom: 24px;
      }

      .form-group label {
        font-size: 0.78rem;
        font-weight: 700;
        color: #d4eeff;
        letter-spacing: 0.03em;
      }

      .form-group input,
      .form-group textarea {
        width: 100%;
        background: #ddeef8;
        border: none;
        border-radius: 6px;
        padding: 9px 12px;
        font-family: 'Nunito', sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--navy);
        outline: none;
        transition: box-shadow 0.2s;
        resize: none;
      }

      .form-group input:focus,
      .form-group textarea:focus {
        box-shadow: 0 0 0 2px var(--orange);
      }

      .form-group textarea {
        height: 110px;
      }

      .btn-signup {
        width: 100%;
        padding: 13px;
        background-color: var(--orange);
        border: none;
        border-radius: 8px;
        color: #fff;
        font-family: 'Nunito', sans-serif;
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s;
      }

      .btn-signup:hover {
        background-color: #e8931a;
        transform: translateY(-1px);
      }

      .btn-signup:active {
        transform: translateY(0);
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 700px) {
        .page-wrapper {
          flex-direction: column;
          gap: 40px;
        }

        .form-card {
          flex: none;
          width: 100%;
          max-width: 400px;
        }
      }
    </style>

    <div class="bg-layer"></div>

    <!-- ── CONTACT HERO ── -->
    <div class="page-wrapper">

      <!-- LEFT -->
      <div class="left-panel">

        <div class="mascot-placeholder">
          <!-- Replace with: <img src="/mascot.png" alt="Mascot" class="mascot-img" /> -->
          <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" width="120" height="120">
            <rect x="30" y="20" width="60" height="48" rx="18" fill="#053F5C" />
            <rect x="57" y="8" width="6" height="14" rx="3" fill="#053F5C" />
            <circle cx="60" cy="7" r="5" fill="#FFA62B" />
            <circle cx="46" cy="40" r="7" fill="#86C5FF" />
            <circle cx="74" cy="40" r="7" fill="#86C5FF" />
            <circle cx="47" cy="41" r="3" fill="#053F5C" />
            <circle cx="75" cy="41" r="3" fill="#053F5C" />
            <path d="M48 54 Q60 63 72 54" stroke="#86C5FF" stroke-width="3" fill="none" stroke-linecap="round" />
            <rect x="36" y="70" width="48" height="32" rx="12" fill="#053F5C" />
            <ellipse cx="22" cy="82" rx="9" ry="14" fill="#053F5C" />
            <ellipse cx="98" cy="82" rx="9" ry="14" fill="#053F5C" />
            <rect x="40" y="100" width="14" height="16" rx="7" fill="#053F5C" />
            <rect x="66" y="100" width="14" height="16" rx="7" fill="#053F5C" />
          </svg>
        </div>

        <div class="heading-block">
          <h1>Get In Touch Today</h1>
          <p>We're happy to hear from you! Don't hesitate to contact us. Our team is here to assist you with any questions you may have.</p>
        </div>

        <ul class="contact-list">
          <li>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
              </svg>
            </div>
            <span>+123-456-789</span>
          </li>
          <li>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <span>abcdefgh123@gmail.com</span>
          </li>
          <li>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/>
              </svg>
            </div>
            <span>John Smith, 39 Acacia Avenue, Silhurst, SH15 6BP, United Kingdom</span>
          </li>
        </ul>
      </div>

      <!-- RIGHT — FORM CARD -->
      <div class="form-card">
        <div class="form-group">
          <label for="first-name">First Name</label>
          <input type="text" id="first-name" name="first-name" autocomplete="given-name" />
        </div>

        <div class="form-group">
          <label for="last-name">Last Name</label>
          <input type="text" id="last-name" name="last-name" autocomplete="family-name" />
        </div>

        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel" />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" autocomplete="email" />
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message"></textarea>
        </div>

        <button class="btn-signup" type="button">SEND</button>
      </div>

    </div>

    <!-- ── FAQ SECTION ── -->
    <FAQ
      items={faqItems}
      title="Frequently Asked Questions"
      subtitle="Everything you need to know about Work Global."
    />

</Layout>