---
import Layout from '../layouts/Layout.astro';
import bgImage from '../assets/background.png?url';
---

<Layout title="WorkGlobal - Swipe. Match. Work" navActive="home">
  <style define:vars={{ bgImage: `url(${bgImage})` }}>
    .bg-layer {
      position: fixed;
      inset: 0;
      background-image: var(--bgImage);
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      opacity: 0.6;
      z-index: -1;
      pointer-events: none;
    }
  </style>

  <div class="bg-layer"></div>

  <section class="w-full min-h-screen px-4 sm:px-8 lg:px-12 py-12">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="inline-flex items-center rounded-full bg-white/70 px-4 py-1.5 text-xs font-bold tracking-[0.12em] text-[#053F5C]">
            GLOBAL CAREER PLATFORM
          </p>
          <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-black uppercase leading-tight text-[#053F5C]">
            Swipe. Match. Work.
          </h1>
          <p class="mt-5 max-w-xl text-base sm:text-lg leading-relaxed text-[#1d4f6a]">
            Find opportunities that actually fit your skills. WorkGlobal connects talent and companies across borders with a fast, modern matching flow.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/support" class="rounded-full bg-[#053F5C] px-6 py-3 text-sm font-bold text-white transition hover:bg-[#0b5b84]">
              Talk to Support
            </a>
            <a href="/about" class="rounded-full border border-[#053F5C]/40 bg-white/70 px-6 py-3 text-sm font-bold text-[#053F5C] transition hover:bg-white">
              Explore WorkGlobal
            </a>
          </div>
        </div>

        <div class="rounded-[2rem] bg-white/70 p-5 sm:p-7 shadow-[0_20px_50px_rgba(5,63,92,0.18)] backdrop-blur-sm">
          <div class="grid gap-4 sm:grid-cols-2">
            <article class="rounded-2xl bg-[#053F5C] p-5 text-white">
              <p class="text-xs font-semibold tracking-[0.1em]">ACTIVE ROLES</p>
              <p class="mt-2 text-3xl font-black">12k+</p>
              <p class="mt-1 text-xs text-[#bfe3ff]">Across product, design, data, and engineering.</p>
            </article>
            <article class="rounded-2xl bg-[#86C5FF] p-5 text-[#053F5C]">
              <p class="text-xs font-semibold tracking-[0.1em]">COUNTRIES</p>
              <p class="mt-2 text-3xl font-black">120+</p>
              <p class="mt-1 text-xs text-[#0a4f72]">Verified global employers and remote teams.</p>
            </article>
            <article class="rounded-2xl bg-white p-5 text-[#053F5C] sm:col-span-2 border border-[#053F5C]/10">
              <p class="text-xs font-semibold tracking-[0.1em]">WHY PEOPLE STAY</p>
              <p class="mt-2 text-sm leading-relaxed">
                Smart matching reduces noise, profile-first applications improve response rates, and one dashboard helps you track every conversation.
              </p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
