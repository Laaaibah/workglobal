---
import Layout from '../layouts/Layout.astro';
import bgImage from '../assets/homepage.png?url';
import logoImage from '../assets/logo.png?url';
import FeatureSection from '../components/FeatureSection.astro';
import EventsSection from '../components/EventsSection.astro';
import feature1 from '../assets/image1.jpeg?url';
import feature2 from '../assets/image2.jpeg?url';
import feature3 from '../assets/image3.jpeg?url';
import layeryBg from '../assets/background.png?url';

const playStoreBadge = "https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg";
const appStoreBadge = "https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg";
---

<Layout title="WorkGlobal - Swipe. Match. Work" navActive="home">
  <main class="relative w-full flex flex-col items-center justify-center overflow-hidden">
    
    <!-- Hero Section: Muzz-Style Responsive -->
    <section class="relative w-full flex flex-col items-center justify-center overflow-hidden min-h-screen md:min-h-[56.25vw]">
      <!-- Full Background Image -->
      <div class="absolute inset-0 z-0">
        <img 
          src={bgImage} 
          alt="" 
          class="w-full h-full object-cover md:h-auto md:object-contain object-center"
        />
      </div>

      <!-- Content on top of image (Vertically & Horizontally Centered) -->
      <div class="relative z-10 flex flex-col items-center text-center px-4 max-w-4xl mx-auto" data-aos="fade-up">
        <!-- Main Logo: Always visible (Restored for mobile) -->
        <div class="mb-4">
          <img 
            src={logoImage} 
            alt="WorkGlobal" 
            class="h-24 sm:h-32 md:h-40 w-auto"
          />
        </div>

        <!-- App Store Links: Side-by-side even on mobile -->
        <div class="flex flex-row items-center justify-center gap-4 sm:gap-6 mt-4">
          <a 
            href="https://instagram.com" 
            target="_blank" 
            rel="noopener noreferrer"
            class="transition-transform hover:scale-105 active:scale-95"
          >
            <img 
              src={playStoreBadge} 
              alt="Get it on Google Play" 
              class="h-10 sm:h-14 md:h-16 w-auto"
            />
          </a>
          <a 
            href="https://instagram.com" 
            target="_blank" 
            rel="noopener noreferrer"
            class="transition-transform hover:scale-105 active:scale-95"
          >
            <img 
              src={appStoreBadge} 
              alt="Download on the App Store" 
              class="h-10 sm:h-14 md:h-16 w-auto"
            />
          </a>
        </div>
      </div>
    </section>

    <!-- Features Group Content (Fixed Background Across Both Sections) -->
    <div 
      class="relative w-full bg-cover bg-center bg-no-repeat bg-fixed isolate"
      style={`background-image: url(${layeryBg});`}
    >
      <!-- Subdued white tint overlay (Fixed Layering) -->
      <div class="absolute inset-0 bg-white/25 backdrop-blur-[2px] -z-10"></div>

      <!-- Features Section 1 (Left Phones, Right Text) -->
      <FeatureSection 
        tagline="How it works"
        title="The match is waiting for you."
        images={[feature1, feature2, feature3]}
        layout="left"
        steps={[
          { number: "01", title: "Build Your Presence", description: "Showcase your global achievements and skills with a profile that stands out across borders.", color: "bg-[#053F5C]" },
          { number: "02", title: "Swipe & Match", description: "Explore verified opportunities tailored specifically to your data-driven matching score.", color: "bg-[#86C5FF]", textColor: "text-[#053F5C]" },
          { number: "03", title: "Connect Instantly", description: "Real-time chat and transparent tracking keep you in the loop through every hiring stage.", color: "bg-white", textColor: "text-[#053F5C]" },
        ]}
      />

      <!-- Features Section 2 (Right Phones, Left Text, Reversed Stack & Tilt) -->
      <FeatureSection 
        tagline="Discover Success"
        title="Your global journey starts here."
        images={[feature3, feature1, feature2]}
        layout="right"
        reverseStack={true}
        tiltDirection="right"
        buttonText="Learn More"
        steps={[
          { number: "04", title: "AI-Driven Insights", description: "Get personalized feedback on your applications based on global market trends and standards.", color: "bg-[#053F5C]" },
          { number: "05", title: "Verified Employers", description: "Connect only with companies that meet our strict transparency and ethical standards.", color: "bg-[#86C5FF]", textColor: "text-[#053F5C]" },
        ]}
      />

      <!-- Events Section (Infinite Marquee) - Now part of the fixed background group -->
      <EventsSection 
        tagline="Upcoming Events"
        title="Never miss a chance to connect."
        events={[
          { type: 'image', src: feature1, title: 'Global Tech Summit', subtitle: 'Networking' },
          { type: 'image', src: feature2, title: 'Freelance Meetup', subtitle: 'Social' },
          { type: 'image', src: feature3, title: 'Creative Workshop', subtitle: 'Learning' },
          { type: 'image', src: feature1, title: 'Career Coaching', subtitle: 'Personal Growth' },
          { type: 'image', src: feature2, title: 'Design Sprint 2024', subtitle: 'Innovation' },
        ]}
      />
    </div>
  </main>
</Layout>

<style>
  /* Custom animations if extra polish is needed */
  main {
    background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.2) 100%);
  }
</style>
