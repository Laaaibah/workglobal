---
import Layout from '../layouts/Layout.astro';
import bgImage from '../assets/homepage.png?url';
import layeryBg from '../assets/background.png?url';
---

<Layout title="WorkGlobal - Pricing" navActive="pricing">
  <style define:vars={{ layeryBg: `url(${layeryBg})` }}>
    .bg-layer {
      position: fixed;
      inset: 0;
      background-image: var(--layeryBg);
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      opacity: 1;
      z-index: -1;
      pointer-events: none;
    }
  </style>

  <div class="bg-layer"></div>

  <main class="w-full relative flex flex-col items-center justify-center overflow-x-hidden">
    
    <!-- Hero Section: Like index.astro -->
    <section class="relative w-full flex flex-col items-center justify-center overflow-hidden min-h-screen md:min-h-[56.25vw]">
      <!-- Full Background Image -->
      <div class="absolute inset-0 z-0">
        <img 
          src={bgImage} 
          alt="" 
          class="w-full h-full object-cover md:h-auto md:object-contain object-center"
        />
      </div>
    </section>

    <!-- Pricing Content Section -->
    <div 
      class="relative w-full flex-1 py-12 flex flex-col items-center justify-start z-10 -mt-16 md:-mt-32"
    >

      <!-- Slider Tabs (Drag & Drop Timeline) -->
      <div class="relative w-full max-w-3xl mx-auto mb-16 px-4 select-none touch-none" id="pricing-slider-container">
        <!-- Connecting Line Background-->
        <div class="absolute top-[102px] left-[2%] right-[2%] h-[8px] bg-[#053F5C] z-0 rounded-full timeline-line"></div>
        
        <!-- Draggable Thumb (The Pill) -->
        <div id="slider-thumb" class="absolute top-[106px] -translate-y-1/2 left-1/2 -translate-x-1/2 w-8 h-12 sm:w-10 sm:h-16 bg-[#86C5FF] rounded-[2rem] border-[4px] border-white shadow-[0_8px_15px_rgba(134,197,255,0.6)] cursor-grab active:cursor-grabbing z-20 transition-all duration-300"></div>
        
        <div class="flex justify-between items-start relative z-10 w-full h-full pointer-events-none">
          <!-- PRO Label Area -->
          <div class="flex flex-col items-center flex-1 relative cursor-pointer pointer-events-auto pricing-click-area group" data-index="0">
            <div class="h-32 sm:h-36 w-full"></div>
            <div class="-translate-x-4 sm:-translate-x-3">
              <span class="pricing-label text-sm sm:text-base font-bold text-[#053F5C] mt-2 transition-all duration-300 uppercase group-hover:scale-105 opacity-70">PRO</span>
            </div>
          </div>
          
          <!-- BASIC Label Area -->
          <div class="flex flex-col items-center flex-1 relative cursor-pointer pointer-events-auto pricing-click-area group" data-index="1">
            <div class="h-32 sm:h-36 w-full"></div>
            <span class="pricing-label text-lg sm:text-xl font-bold bg-[#E3F1FB] text-[#053F5C] px-5 sm:px-6 py-2 rounded-xl mt-0 transition-all duration-300 uppercase shadow-sm scale-110">BASIC</span>
          </div>

          <!-- ENTERPRISE Label Area -->
          <div class="flex flex-col items-center flex-1 relative cursor-pointer pointer-events-auto pricing-click-area group" data-index="2">
            <div class="h-32 sm:h-36 w-full"></div>
            <div class="translate-x-4 sm:translate-x-3">
              <span class="pricing-label text-sm sm:text-base font-bold text-[#053F5C] mt-2 transition-all duration-300 uppercase group-hover:scale-105 opacity-70">ENTERPRISE</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Carousel / Slider -->
      <div class="relative w-full max-w-6xl mx-auto overflow-hidden px-0 md:px-12 py-8">
        <div class="slider-track flex items-center transition-transform duration-500 ease-out" data-active="1">
          
          <!-- Card 1: PRO -->
          <div class="pricing-card w-full md:w-1/3 flex-shrink-0 px-4 transition-all duration-500 inactive">
            <div class="bg-white/95 backdrop-blur-sm rounded-[2rem] p-8 flex flex-col items-center text-center border border-white/40 min-h-[400px]">
              <h3 class="text-3xl font-extrabold text-[#FA9A3E] mb-8 mt-4 tracking-wide">29$/month</h3>
              <ul class="text-left space-y-5 text-[15px] text-gray-800 w-full px-2">
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Dedicated account manager</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Full API access & integrations</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Advanced security & compliance</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Team collaboration tools</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Tailored onboarding & training</li>
              </ul>
            </div>
          </div>

          <!-- Card 2: BASIC -->
          <div class="pricing-card w-full md:w-1/3 flex-shrink-0 px-4 transition-all duration-500 active">
            <div class="relative rounded-[2rem] p-10 flex flex-col items-center justify-center text-center overflow-hidden min-h-[440px] border border-white border-opacity-50"
                 style="background: linear-gradient(135deg, #ffffff 0%, #E3F1FB 100%);">
              <!-- Swirl decoration for Basic inside card -->
              <div class="absolute inset-0 bg-cover bg-bottom opacity-20 mix-blend-multiply pointer-events-none" style={`background-image: url(${layeryBg});`}></div>
              
              <div class="relative z-10 w-full h-full flex flex-col items-center justify-center">
                <h3 class="text-5xl font-extrabold text-[#FA9A3E] tracking-wider drop-shadow-sm">0$/month</h3>
              </div>
            </div>
          </div>

          <!-- Card 3: ENTERPRISE -->
          <div class="pricing-card w-full md:w-1/3 flex-shrink-0 px-4 transition-all duration-500 inactive">
            <div class="bg-white/95 backdrop-blur-sm rounded-[2rem] p-8 flex flex-col items-center text-center border border-white/40 min-h-[400px]">
              <h3 class="text-2xl font-extrabold text-[#FA9A3E] mb-8 mt-4 tracking-wide uppercase">Custom Pricing</h3>
              <ul class="text-left space-y-5 text-[15px] text-gray-800 w-full px-2">
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Dedicated account manager</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Full API access & integrations</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Advanced security & compliance</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Team collaboration tools</li>
                <li class="flex items-start"><span class="mr-3 font-bold text-black text-lg leading-none">✓</span> Tailored onboarding & training</li>
              </ul>
            </div>
          </div>

        </div>
      </div>

      <!-- Start Free Trial Button -->
      <div class="mt-8 mb-16 relative z-10">
        <a href="/trial" class="inline-block bg-[#86C5FF] text-[#053F5C] font-extrabold text-xl md:text-2xl px-12 py-5 rounded-[1.25rem] shadow-[0_8px_25px_rgba(134,197,255,0.5)] hover:shadow-[0_12px_35px_rgba(134,197,255,0.7)] hover:-translate-y-1 transition-all duration-300 uppercase tracking-widest">
          Start Free Trial
        </a>
      </div>

    </div>
  </main>
</Layout>

<style>
  /* Base Track Transform Strategy */
  /* On Mobile: Cards are 100% width, translates by 100vw */
  @media (max-width: 767px) {
    .slider-track[data-active="0"] { transform: translateX(0%); }
    .slider-track[data-active="1"] { transform: translateX(-100%); }
    .slider-track[data-active="2"] { transform: translateX(-200%); }
  }

  /* On Desktop: Cards stay exactly where they are, and scale in place */
  @media (min-width: 768px) {
    .slider-track { transform: translateX(0) !important; }
  }

  /* Inactive / Active Card Scaling */
  .pricing-card.active {
    transform: scale(1.05);
    opacity: 1;
    z-index: 20;
  }
  
  .pricing-card.inactive {
    transform: scale(0.85);
    opacity: 0.6;
    z-index: 10;
  }
</style>

<script>
  function setupPricingSlider() {
    const container = document.getElementById('pricing-slider-container');
    const thumb = document.getElementById('slider-thumb');
    const slider = document.querySelector('.slider-track');
    const cards = document.querySelectorAll('.pricing-card');
    const labels = document.querySelectorAll('.pricing-label');
    const clickAreas = document.querySelectorAll('.pricing-click-area');

    if (!container || !thumb || !slider) return;

    let isDragging = false;
    let currentIndex = 1;

    // The snap positions in percentage of container width
    const snapPositions = [16.666, 50, 83.333];

    // Function to update visual state based on index
    function setPosition(index, animate = true) {
      if (index < 0) index = 0;
      if (index > 2) index = 2;
      currentIndex = index;

      // Move thumb gracefully
      thumb.style.transition = animate ? 'left 0.4s cubic-bezier(0.25, 1, 0.5, 1)' : 'none';
      thumb.style.left = `${snapPositions[index]}%`;

      // Update Labels
      labels.forEach((label, i) => {
        if (i === index) {
          label.className = 'pricing-label text-lg sm:text-xl font-bold bg-[#E3F1FB] text-[#053F5C] px-5 sm:px-6 py-2 rounded-xl mt-0 transition-all duration-300 uppercase shadow-sm scale-110';
        } else {
          label.className = 'pricing-label text-xs sm:text-sm font-bold text-[#053F5C] mt-2 transition-all duration-300 uppercase scale-100 opacity-70 hover:opacity-100';
        }
      });

      // Update Cards
      slider.setAttribute('data-active', index.toString());
      cards.forEach((c, i) => {
        if (i === index) {
          c.classList.add('active');
          c.classList.remove('inactive');
        } else {
          c.classList.remove('active');
          c.classList.add('inactive');
        }
      });
    }

    // Initialize to BASIC (index 1)
    setPosition(1, false);

    // Make areas clickable to jump thumb to position
    clickAreas.forEach((area, index) => {
      area.addEventListener('click', () => {
        setPosition(index);
      });
    });

    // Drag Logic using Pointer Events
    let startX = 0;
    let startLeftPct = 0;

    function onPointerDown(e) {
      isDragging = true;
      thumb.style.transition = 'none'; // disable transition while dragging
      thumb.classList.add('cursor-grabbing', 'scale-95');
      thumb.classList.remove('cursor-grab');
      
      startX = e.clientX || (e.touches && e.touches.length > 0 ? e.touches[0].clientX : 0);
      
      // Calculate current left percentage natively
      const containerRect = container.getBoundingClientRect();
      const thumbRect = thumb.getBoundingClientRect();
      // Center of thumb relative to container
      const currentPixels = (thumbRect.left + thumbRect.width / 2) - containerRect.left;
      startLeftPct = (currentPixels / containerRect.width) * 100;
      
      document.addEventListener('pointermove', onPointerMove, { passive: false });
      document.addEventListener('pointerup', onPointerUp);
      document.addEventListener('pointercancel', onPointerUp);
      
      if (e.type === 'touchstart') {
        document.addEventListener('touchmove', onPointerMove, { passive: false });
        document.addEventListener('touchend', onPointerUp);
        document.addEventListener('touchcancel', onPointerUp);
      }
    }

    function onPointerMove(e) {
      if (!isDragging) return;
      
      const currentX = e.clientX || (e.touches && e.touches.length > 0 ? e.touches[0].clientX : 0);
      const deltaX = currentX - startX;
      
      const containerRect = container.getBoundingClientRect();
      const deltaPct = (deltaX / containerRect.width) * 100;
      
      let newLeftPct = startLeftPct + deltaPct;
      
      // Prevent scrolling if user is dragging horizontally
      if (Math.abs(deltaX) > 5 && e.cancelable) {
          e.preventDefault();
      }
      
      // Clamp bounds slightly outside snap points for bounce effect
      if (newLeftPct < 10) newLeftPct = 10;
      if (newLeftPct > 90) newLeftPct = 90;
      
      thumb.style.left = `${newLeftPct}%`;
    }

    function onPointerUp(e) {
      if (!isDragging) return;
      isDragging = false;
      thumb.classList.remove('cursor-grabbing', 'scale-95');
      thumb.classList.add('cursor-grab');
      
      document.removeEventListener('pointermove', onPointerMove);
      document.removeEventListener('pointerup', onPointerUp);
      document.removeEventListener('pointercancel', onPointerUp);
      document.removeEventListener('touchmove', onPointerMove);
      document.removeEventListener('touchend', onPointerUp);
      document.removeEventListener('touchcancel', onPointerUp);
      
      // Determine nearest snap point based on dropped position
      const containerRect = container.getBoundingClientRect();
      const thumbRect = thumb.getBoundingClientRect();
      const finalX = (thumbRect.left + thumbRect.width / 2) - containerRect.left;
      const finalPct = (finalX / containerRect.width) * 100;
      
      // Find nearest index
      let closestIndex = 0;
      let minDiff = Math.abs(finalPct - snapPositions[0]);
      
      for(let i = 1; i < snapPositions.length; i++) {
        const diff = Math.abs(finalPct - snapPositions[i]);
        if (diff < minDiff) {
          minDiff = diff;
          closestIndex = i;
        }
      }
      
      // Snap to closest position
      setPosition(closestIndex);
    }

    thumb.addEventListener('pointerdown', onPointerDown);
    thumb.addEventListener('touchstart', onPointerDown, {passive: false});
  }

  // Run immediately and after View Transitions
  setupPricingSlider();
  document.addEventListener('astro:page-load', setupPricingSlider);
  document.addEventListener('astro:after-swap', setupPricingSlider);
</script>
