---
interface Props {
  images: string[];
  align?: 'left' | 'right';
  reverseStack?: boolean;
  tiltDirection?: 'left' | 'right';
}

const { images, align = 'left', reverseStack = false, tiltDirection = 'left' } = Astro.props;
---

<!-- Triple Phone Stack -->
<div class={`flex justify-center items-center ${align === 'left' ? 'lg:justify-start' : 'lg:justify-end'} -space-x-32 sm:-space-x-44 phone-stack-container h-[550px] isolate`}>
  {images.map((image, i) => {
    // Determine configuration index based on stack order
    const configIndex = reverseStack ? (2 - i) : i;
    const tiltMult = tiltDirection === 'right' ? 1 : -1;

    // Stacking configurations (from Back to Front order)
    const configs = [
      { rotate: `${12 * tiltMult}deg`, z: "10", scale: "0.90", opacity: "0.8", delay: 200, shadow: "shadow-lg" }, // Back
      { rotate: `${6 * tiltMult}deg`,  z: "20", scale: "0.95", opacity: "0.9", delay: 100, shadow: "shadow-2xl" }, // Middle
      { rotate: "0deg",              z: "30", scale: "1.0",  opacity: "1.0", delay: 0,   shadow: "shadow-[20px_40px_100px_-20px_rgba(0,0,0,0.5)]" }, // Front
    ];
    
    const config = configs[configIndex] || configs[2];

    return (
      <div 
        class={`feature-card relative w-[240px] h-[420px] sm:w-[280px] sm:h-[500px] rounded-[3rem] border-[10px] border-white ${config.shadow} overflow-hidden transition-all duration-700 bg-black group`}
        style={`z-index: ${config.z}; transform: rotate(${config.rotate}) scale(${config.scale}); opacity: ${config.opacity}; transition-delay: ${config.delay}ms;`}
      >
        <!-- Mock Status Bar -->
        <div class="absolute top-0 left-0 w-full h-8 flex justify-between items-center px-8 pt-4 z-20 pointer-events-none">
          <span class="text-[10px] font-bold text-white">9:41</span>
          <div class="flex gap-1.5 opacity-80">
              <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z"/></svg>
          </div>
        </div>

        <!-- Notch -->
        <div class="absolute top-0 left-1/2 -track-x-1/2 w-32 h-7 bg-white rounded-b-3xl z-30 transition-transform group-hover:scale-y-110 isolate">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-1bg-black/20 rounded-full"></div>
        </div>

        <!-- Image Content -->
        <div class="absolute inset-0 z-10">
          <img 
            src={image} 
            alt="App feature" 
            class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110"
          />
          <!-- Text Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex flex-col justify-end p-8">
             <div class="w-12 h-1 bg-white/40 rounded-full mb-4"></div>
             <div class="h-4 w-3/4 bg-white/20 rounded mb-2"></div>
             <div class="h-4 w-1/2 bg-white/10 rounded"></div>
          </div>
        </div>

        <!-- Glassy Border -->
        <div class="absolute inset-0 z-15 pointer-events-none border-[1px] border-white/20 rounded-[inherit]"></div>
      </div>
    );
  })}
</div>

<style is:global>
  .feature-card {
    will-change: transform, z-index;
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .phone-stack-container:hover .feature-card {
     opacity: 0.6;
     filter: blur(2px) grayscale(0.2);
  }

  .phone-stack-container .feature-card:hover {
     opacity: 1 !important;
     scale: 1.05 !important;
     rotate: 0deg !important;
     filter: none !important;
     translate: 0 -30px;
     z-index: 50 !important;
     box-shadow: 0 50px 100px -20px rgba(0,0,0,0.5);
  }
</style>
