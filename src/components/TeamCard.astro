---
// TeamCard.astro — reusable team member card
// Props: name, role, image (optional path)

interface Props {
  name: string;
  role: string;
  image?: string;
}

const { name, role, image } = Astro.props;
---

<div class="team-card">
  <div class="avatar-wrap">
    {image
      ? <img src={image} alt={name} class="avatar-img" />
      : <div class="avatar-placeholder"></div>
    }
  </div>
  <p class="member-name">{name}</p>
  <span class="member-role">{role}</span>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap');

  .team-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 16px 14px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 120px;
    box-shadow: 0 4px 20px rgba(5, 63, 92, 0.12);
    font-family: 'Nunito', sans-serif;
    /* cards are positioned absolutely by the parent page */
  }

  .avatar-wrap {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Blue gradient circle placeholder — matches the reference image */
  .avatar-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 35%, #86C5FF 0%, #378ADD 45%, #053F5C 100%);
  }

  .member-name {
    font-size: 0.7rem;
    font-weight: 900;
    color: #053F5C;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin: 0;
  }

  .member-role {
    display: inline-block;
    background: #FFA62B;
    color: #ffffff;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
  }
</style>
